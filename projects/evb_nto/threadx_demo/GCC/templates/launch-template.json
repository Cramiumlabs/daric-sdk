{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "testsuite Debug",
            "cwd": "${workspaceFolder}/testsuite",
            "executable": "./GCC/out/testsuite.elf",
            "gdbPath" : "<path to arm-none-eabi-gdb>",
            "request": "attach",
            "type": "cortex-debug",
            "servertype" : "external",
            // JLinkGDBServerCL.exe -select USB -device Cortex-M7 -endian little -if SWD -speed 4000
            // -noir -noLocalhostOnly -nologtofile -port 2331 -SWOPort 2332 -TelnetPort 2333 -rtos GDBServer\RTOSPlugin_Azure
            "gdbTarget": "<jlink gdb server ip>:<gdb server port>",
            "rtos": "Azure",
            "preAttachCommands": [
                "monitor semihosting enable",
                "monitor semihosting breakOnError",
                // telnet <jlink gdb server ip> <telnet port>
                "monitor semihosting IOClient 1",
            ],
            "overrideResetCommands": [
                // RCURST1: reset core system
                "monitor memU32 0x40040084 0x000055aa",
                "monitor reset",
                "load",
            ],
        }
    ]
}
