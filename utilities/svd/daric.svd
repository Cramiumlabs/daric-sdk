        <usage>registers</usage>
      </addressBlock>
      <interrupt><name>GPIO</name><value>144</value></interrupt>
      <registers>
        <!-- AFSEL Registers (0x00 - 0x2C) -->
        <register><name>AFSEL_PAL</name><addressOffset>0x00</addressOffset></register>
        <register><name>AFSEL_PAH</name><addressOffset>0x04</addressOffset></register>
        <register><name>AFSEL_PBL</name><addressOffset>0x08</addressOffset></register>
        <register><name>AFSEL_PBH</name><addressOffset>0x0C</addressOffset></register>
        <register><name>AFSEL_PCL</name><addressOffset>0x10</addressOffset></register>
        <register><name>AFSEL_PCH</name><addressOffset>0x14</addressOffset></register>
        <register><name>AFSEL_PDL</name><addressOffset>0x18</addressOffset></register>
        <register><name>AFSEL_PDH</name><addressOffset>0x1C</addressOffset></register>
        <register><name>AFSEL_PEL</name><addressOffset>0x20</addressOffset></register>
        <register><name>AFSEL_PEH</name><addressOffset>0x24</addressOffset></register>
        <register><name>AFSEL_PFL</name><addressOffset>0x28</addressOffset></register>
        <register><name>AFSEL_PFH</name><addressOffset>0x2C</addressOffset></register>

        <!-- INTCR Registers (0x100 - 0x11C) -->
        <cluster>
            <name>INTCR</name>
