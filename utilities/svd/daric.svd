<?xml version="1.0" encoding="utf-8"?>
<device schemaVersion="1.3" xmlns:xs="http://www.w3.org/2001/XMLSchema-instance" xs:noNamespaceSchemaLocation="CMSIS-SVD.xsd">
  <vendor>Daric</vendor>
  <vendorID>Daric</vendorID>
  <name>Daric</name>
  <series>Daric</series>
  <version>1.0</version>
  <description>Daric ARM Cortex-M7 Microcontroller</description>
  <licenseText>
    Copyright 2024 CrossBar, Inc.
  </licenseText>
  <cpu>
    <name>CM7</name>
    <revision>r1p2</revision>
    <endian>little</endian>
    <mpuPresent>true</mpuPresent>
    <fpuPresent>true</fpuPresent>
    <nvicPrioBits>3</nvicPrioBits>
    <vendorSystickConfig>true</vendorSystickConfig>
  </cpu>
  <addressUnitBits>8</addressUnitBits>
  <width>32</width>
  <size>32</size>
  <resetValue>0x00000000</resetValue>
  <resetMask>0xFFFFFFFF</resetMask>

  <peripherals>
    <!-- MDMA: Direct Memory Access Controller -->
    <peripheral>
      <name>MDMA</name>
      <description>Direct Memory Access Controller</description>
      <baseAddress>0x40011000</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x2000</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register><name>DMA_STAT</name><description>DMA status</description><addressOffset>0x0000</addressOffset><access>read-only</access></register>
        <register><name>DMA_CFG</name><description>DMA configuration</description><addressOffset>0x0004</addressOffset><access>write-only</access></register>
        <register><name>DMA_CTRL_BASE_PTR</name><description>Channel control data base pointer</description><addressOffset>0x0008</addressOffset></register>
        <register><name>DMA_ALT_BASE_PTR</name><description>Channel alternate control data base pointer</description><addressOffset>0x000C</addressOffset><access>read-only</access></register>
        <register><name>DMA_CH_WREQ_STAT</name><description>Channel wait on request status</description><addressOffset>0x0010</addressOffset><access>read-only</access></register>
        <register><name>DMA_CH_SW_REQ</name><description>Channel software request</description><addressOffset>0x0014</addressOffset><access>write-only</access></register>
        <register><name>DMA_CH_REQMASK_SET</name><description>Channel request mask set</description><addressOffset>0x0020</addressOffset></register>
        <register><name>DMA_CH_REQMASK_CLR</name><description>Channel request mask clear</description><addressOffset>0x0024</addressOffset><access>write-only</access></register>
        <register><name>DMA_CH_ENSET</name><description>Channel enable set</description><addressOffset>0x0028</addressOffset></register>
        <register><name>DMA_CH_ENCLR</name><description>Channel enable clear</description><addressOffset>0x002C</addressOffset><access>write-only</access></register>
        <register><name>DMA_CHPRIALT_SET</name><description>Channel primary-alternate set</description><addressOffset>0x0030</addressOffset></register>
        <register><name>DMA_CHPRIALT_CLR</name><description>Channel primary-alternate clear</description><addressOffset>0x0034</addressOffset><access>write-only</access></register>
        <register><name>DMA_CH_PRIO_SET</name><description>Channel priority set</description><addressOffset>0x0038</addressOffset></register>
        <register><name>DMA_CH_PRIO_CLR</name><description>Channel priority clear</description><addressOffset>0x003C</addressOffset><access>write-only</access></register>

        <!-- Offset 0x1000 registers (MDMAREQ block) -->
        <register>
            <name>DMA_CHEVSEL[%s]</name>
            <description>Event Selection for Channels</description>
            <addressOffset>0x1000</addressOffset>
            <dim>8</dim>
            <dimIncrement>0x4</dimIncrement>
        </register>
        <register>
            <name>DMA_CH_REQ[%s]</name>
            <description>DMA Request Function Enable</description>
            <addressOffset>0x1020</addressOffset>
            <dim>8</dim>
            <dimIncrement>0x4</dimIncrement>
        </register>
        <register>
            <name>DMA_CH_SR_REQ[%s]</name>
            <description>DMA Request Status</description>
            <addressOffset>0x1040</addressOffset>
            <dim>8</dim>
            <dimIncrement>0x4</dimIncrement>
            <access>read-only</access>
        </register>
      </registers>
    </peripheral>

    <!-- CGU: Clock Generation Unit -->
    <peripheral>
      <name>CGU</name>
      <description>Clock Generation Unit</description>
      <baseAddress>0x40040000</baseAddress>
      <addressBlock><offset>0</offset><size>0x80</size><usage>registers</usage></addressBlock>
      <registers>
         <register><name>CGUSEC</name><description>CGU Security Related</description><addressOffset>0x0000</addressOffset></register>
         <register><name>CGULP</name><description>CGU Low Power</description><addressOffset>0x0004</addressOffset></register>
         <register><name>CGU_SEED</name><description>CLK Cipher Seed</description><addressOffset>0x0008</addressOffset></register>
         <register><name>CGU_SEEDAR</name><description>CLK Cipher Seed AR</description><addressOffset>0x000C</addressOffset><access>write-only</access></register>
         <register><name>CGUSELO</name><description>CLKTOP Source Select</description><addressOffset>0x0010</addressOffset></register>
         
         <register>
             <name>CGUFD_FCLK</name>
             <description>FCLK Freq Div</description>
             <addressOffset>0x0014</addressOffset>
             <fields>
                 <field><name>NORMAL</name><description>Normal setting</description><bitOffset>0</bitOffset><bitWidth>8</bitWidth></field>
                 <field><name>LP</name><description>Low power setting</description><bitOffset>8</bitOffset><bitWidth>8</bitWidth></field>
                 <field><name>MIN_CYCLE</name><description>Min cycle</description><bitOffset>16</bitOffset><bitWidth>8</bitWidth></field>
                 <field><name>MIN_CYCLE_LP</name><description>Min cycle for lp</description><bitOffset>24</bitOffset><bitWidth>8</bitWidth></field>
             </fields>
         </register>
         <register base="CGUFD_FCLK"><name>CGUFD_ACLK</name><description>ACLK Freq Div</description><addressOffset>0x0018</addressOffset></register>
         <register base="CGUFD_FCLK"><name>CGUFD_HCLK</name><description>HCLK Freq Div</description><addressOffset>0x001C</addressOffset></register>
         <register base="CGUFD_FCLK"><name>CGUFD_ICLK</name><description>ICLK Freq Div</description><addressOffset>0x0020</addressOffset></register>
         <register base="CGUFD_FCLK"><name>CGUFD_PCLK</name><description>PCLK Freq Div</description><addressOffset>0x0024</addressOffset></register>
         <register base="CGUFD_FCLK"><name>CGUFD_AOCLK</name><description>AOCLK Freq Div</description><addressOffset>0x0028</addressOffset></register>

         <register><name>CGUSET</name><description>CGU Setting Enable</description><addressOffset>0x002C</addressOffset><access>write-only</access></register>
         <register><name>CGUSEL1</name><description>CLKSYS Source Select</description><addressOffset>0x0030</addressOffset></register>
         <register><name>CGUFD_PKECLK</name><description>PKECLK Freq Div</description><addressOffset>0x0034</addressOffset></register>
         <register><name>CGUFD_AORAM</name><description>AORAM Freq Div</description><addressOffset>0x0038</addressOffset></register>
         <register><name>CGUFD_PER</name><description>CLKPER Freq Div</description><addressOffset>0x003C</addressOffset></register>
         <register><name>CGUFSFREQ0</name><description>Freq Sensor FCLK/CLKPKE</description><addressOffset>0x0040</addressOffset><access>read-only</access></register>
         <register><name>CGUFSFREQ1</name><description>Freq Sensor CLKAO/CLKRAM</description><addressOffset>0x0044</addressOffset><access>read-only</access></register>
         <register><name>CGUFSFREQ2</name><description>Freq Sensor OSC/XTAL</description><addressOffset>0x0048</addressOffset><access>read-only</access></register>
         <register><name>CGUFSFREQ3</name><description>Freq Sensor PLL0/1</description><addressOffset>0x004C</addressOffset><access>read-only</access></register>
         <register><name>CGUFSVLD</name><description>Freq Valid</description><addressOffset>0x0050</addressOffset><access>read-only</access></register>
         <register><name>CGUFSCR</name><description>Freq Sensor Reference</description><addressOffset>0x0054</addressOffset></register>
         <register><name>CGUACLKGR</name><description>ACLK Group Sub-gate</description><addressOffset>0x0060</addressOffset></register>
         <register><name>CGUHCLKGR</name><description>HCLK Group Sub-gate</description><addressOffset>0x0064</addressOffset></register>
         <register><name>CGUICLKGR</name><description>ICLK Group Sub-gate</description><addressOffset>0x0068</addressOffset></register>
         <register><name>CGUPCLKGR</name><description>PCLK Group Sub-gate</description><addressOffset>0x006C</addressOffset></register>
      </registers>
    </peripheral>

    <!-- RCU: Reset Controller Unit -->
    <peripheral>
      <name>RCU</name>
      <description>Reset Controller Unit</description>
      <baseAddress>0x40040080</baseAddress>
      <addressBlock><offset>0</offset><size>0x10</size><usage>registers</usage></addressBlock>
      <registers>
        <register><name>RCURST0</name><description>Reset Chip System</description><addressOffset>0x0000</addressOffset><access>write-only</access></register>
        <register><name>RCURST1</name><description>Reset Core System</description><addressOffset>0x0004</addressOffset><access>write-only</access></register>
        <register><name>RCUSRCFR</name><description>Reset Source Flags</description><addressOffset>0x0008</addressOffset><access>read-only</access>
           <fields>
             <field><name>CORE_RESET_SW</name><description>Software Core Reset</description><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
             <field><name>WDT_RESET</name><description>Watchdog Reset</description><bitOffset>1</bitOffset><bitWidth>1</bitWidth></field>
             <field><name>CMS_RESET</name><description>Chip Mode Reset</description><bitOffset>2</bitOffset><bitWidth>1</bitWidth></field>
             <field><name>SYS_RESET</name><description>System Reset</description><bitOffset>3</bitOffset><bitWidth>1</bitWidth></field>
             <field><name>PAD_RESET</name><description>Pad Reset</description><bitOffset>4</bitOffset><bitWidth>1</bitWidth></field>
             <field><name>SYS_RESET_SW</name><description>Software System Reset</description><bitOffset>5</bitOffset><bitWidth>1</bitWidth></field>
             <field><name>SEC_RESET</name><description>Security Reset</description><bitOffset>6</bitOffset><bitWidth>1</bitWidth></field>
             <field><name>VD_RESET</name><description>Voltage Detector Reset</description><bitOffset>7</bitOffset><bitWidth>1</bitWidth></field>
             <field><name>CHIP_RESET</name><description>Chip Reset</description><bitOffset>8</bitOffset><bitWidth>1</bitWidth></field>
           </fields>
        </register>
      </registers>
    </peripheral>

    <!-- IPC: IP Control (PLL) -->
    <peripheral>
      <name>IPC</name>
      <description>IP Control (PLL)</description>
      <baseAddress>0x40040090</baseAddress>
      <addressBlock><offset>0</offset><size>0x70</size><usage>registers</usage></addressBlock>
      <registers>
        <register><name>IPCAR</name><description>IP Control AR</description><addressOffset>0x0000</addressOffset><access>write-only</access></register>
        <register><name>IPCEN</name><description>IP Control Enable</description><addressOffset>0x0004</addressOffset></register>
        <register><name>IPCLPEN</name><description>IP Low Power Enable</description><addressOffset>0x0008</addressOffset></register>
        <register><name>IPCOSC</name><description>IP OSC Control</description><addressOffset>0x000C</addressOffset></register>
        <register><name>IPCPLL_MN</name><description>PLL MN Parameter</description><addressOffset>0x0010</addressOffset></register>
        <register><name>IPCPLL_F</name><description>PLL F Parameter</description><addressOffset>0x0014</addressOffset></register>
        <register><name>IPCPLL_Q</name><description>PLL Q Parameter</description><addressOffset>0x0018</addressOffset></register>
        <register><name>IPCCR</name><description>IPC Control</description><addressOffset>0x001C</addressOffset></register>
      </registers>
    </peripheral>

    <!-- WDT: Watchdog Timer -->
    <peripheral>
      <name>WDT</name>
      <description>Watchdog Timer</description>
      <baseAddress>0x40041000</baseAddress>
      <addressBlock><offset>0</offset><size>0x1000</size><usage>registers</usage></addressBlock>
      <registers>
         <register><name>WDT_VAL</name><description>Load value</description><addressOffset>0x0000</addressOffset></register>
         <register><name>WDT_CNT</name><description>Counter value</description><addressOffset>0x0004</addressOffset></register>
         <register><name>WDT_CFG</name><description>Configuration</description><addressOffset>0x0008</addressOffset>
            <fields>
                <field><name>IRQ_EN</name><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                <field><name>RESET_EN</name><bitOffset>1</bitOffset><bitWidth>1</bitWidth></field>
            </fields>
         </register>
         <register><name>WDT_CLR</name><description>Clear counter</description><addressOffset>0x000C</addressOffset><access>write-only</access></register>
         <register><name>WDT_INTRAW</name><description>Raw Interrupt</description><addressOffset>0x0010</addressOffset><access>read-only</access></register>
         <register><name>WDT_INT</name><description>Masked Interrupt</description><addressOffset>0x0014</addressOffset><access>read-only</access></register>
         <register><name>WDT_LOCKCR</name><description>Lock Configuration</description><addressOffset>0x0C00</addressOffset></register>
         <register><name>WDT_ITCR</name><description>Internal Test Config</description><addressOffset>0x0F00</addressOffset></register>
         <register><name>WDT_ITOP</name><description>Internal Test Op</description><addressOffset>0x0F04</addressOffset></register>
      </registers>
    </peripheral>

    <!-- DUART: Debug UART -->
    <peripheral>
      <name>DUART</name>
      <description>Debug UART</description>
      <baseAddress>0x40042000</baseAddress>
      <addressBlock><offset>0</offset><size>0x1000</size><usage>registers</usage></addressBlock>
      <registers>
        <register><name>TXDATA</name><description>TX Data</description><addressOffset>0x0000</addressOffset></register>
        <register><name>TXEN</name><description>TX Enable</description><addressOffset>0x0004</addressOffset>
            <fields><field><name>EN</name><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field></fields>
        </register>
        <register><name>BUSY</name><description>Busy Status</description><addressOffset>0x0008</addressOffset><access>read-only</access>
            <fields><field><name>BUSY</name><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field></fields>
        </register>
        <register><name>ETU</name><description>TX ETU</description><addressOffset>0x000C</addressOffset></register>
      </registers>
    </peripheral>

    <!-- EVC: Event Controller -->
    <peripheral>
        <name>EVC</name>
        <description>Event Controller</description>
        <baseAddress>0x40044000</baseAddress>
        <addressBlock><offset>0</offset><size>0x1000</size><usage>registers</usage></addressBlock>
        <registers>
            <register><name>CM7EVSEL[%s]</name><description>CM7 Event Select</description><addressOffset>0x0000</addressOffset><dim>8</dim><dimIncrement>0x4</dimIncrement></register>
            <register><name>CM7_EVEN</name><description>CM7 Event Enable</description><addressOffset>0x0020</addressOffset></register>
            <register><name>CM7_EVFR</name><description>CM7 Event Flag</description><addressOffset>0x0024</addressOffset></register>
            <register><name>TMREVSEL</name><description>Timer Event Select</description><addressOffset>0x0030</addressOffset></register>
            <register><name>TMR_EVEN</name><description>Timer Event Enable</description><addressOffset>0x0034</addressOffset></register>
            
            <register><name>IF_EVEN[%s]</name><description>Interface Event Enable</description><addressOffset>0x0040</addressOffset><dim>8</dim><dimIncrement>0x4</dimIncrement></register>
            <register><name>IF_EVERR_FR[%s]</name><description>Interface Event Error Flag</description><addressOffset>0x0060</addressOffset><dim>8</dim><dimIncrement>0x4</dimIncrement></register>
            
            <register><name>CM7_ERRFR</name><description>CM7 Error Flag</description><addressOffset>0x0080</addressOffset></register>
            <register><name>CM7_ERRCR</name><description>CM7 Error Enable</description><addressOffset>0x0084</addressOffset></register>
            
            <register><name>RRCEVSEL[%s]</name><description>RRC Event Select</description><addressOffset>0x0090</addressOffset><dim>4</dim><dimIncrement>0x4</dimIncrement></register>
            <register><name>RRC_EVEN</name><description>RRC Event Enable</description><addressOffset>0x00A0</addressOffset></register>
        </registers>
    </peripheral>
    <!-- UART0: Template for UARTs with UDMA Channels -->
    <peripheral>
      <name>UART0</name>
      <description>UART0 Interface</description>
      <baseAddress>0x50101000</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x1000</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>UART0_RX</name>
        <description>UART0 RX Interrupt</description>
        <value>64</value>
      </interrupt>
      <interrupt>
        <name>UART0_TX</name>
        <description>UART0 TX Interrupt</description>
        <value>65</value>
      </interrupt>
       <interrupt>
        <name>UART0_RX_CHAR</name>
        <description>UART0 RX Char Interrupt</description>
        <value>66</value>
      </interrupt>
       <interrupt>
        <name>UART0_ERR</name>
        <description>UART0 Error Interrupt</description>
        <value>67</value>
      </interrupt>

      <registers>
        <!-- Generic UDMA RX Channel -->
        <cluster>
          <name>RX_CHANNEL</name>
          <description>UDMA RX Channel Registers</description>
          <addressOffset>0x00</addressOffset>
          <register>
            <name>SADDR</name>
            <description>RX Buffer Start Address</description>
            <addressOffset>0x00</addressOffset>
            <resetValue>0x00000000</resetValue>
          </register>
          <register>
            <name>SIZE</name>
            <description>RX Buffer Size</description>
            <addressOffset>0x04</addressOffset>
            <resetValue>0x00000000</resetValue>
          </register>
          <register>
            <name>CFG</name>
            <description>RX Configuration</description>
            <addressOffset>0x08</addressOffset>
            <resetValue>0x00000000</resetValue>
            <fields>
                <field>
                    <name>CONT</name>
                    <description>Continuous Mode</description>
                    <bitOffset>0</bitOffset>
                    <bitWidth>1</bitWidth>
                </field>
                <field>
                    <name>SIZE</name>
                    <description>Data Size (00=8bit, 01=16bit, 10=32bit)</description>
                    <bitOffset>1</bitOffset>
                    <bitWidth>2</bitWidth>
                </field>
                <field>
                    <name>EN</name>
                    <description>Enable Channel</description>
                    <bitOffset>4</bitOffset>
                    <bitWidth>1</bitWidth>
                </field>
                <field>
                    <name>PENDING</name>
                    <description>Transfer Pending Status</description>
                    <bitOffset>5</bitOffset>
                    <bitWidth>1</bitWidth>
                </field>
                <field>
                    <name>CLR</name>
                    <description>Clear Channel</description>
                    <bitOffset>6</bitOffset>
                    <bitWidth>1</bitWidth>
                </field>
            </fields>
          </register>
          <!-- Interrupt Config might be restricted or generic -->
        </cluster>

        <!-- Generic UDMA TX Channel -->
        <cluster>
          <name>TX_CHANNEL</name>
          <description>UDMA TX Channel Registers</description>
          <addressOffset>0x10</addressOffset>
          <register>
            <name>SADDR</name>
            <description>TX Buffer Start Address</description>
            <addressOffset>0x00</addressOffset>
            <resetValue>0x00000000</resetValue>
          </register>
          <register>
            <name>SIZE</name>
            <description>TX Buffer Size</description>
            <addressOffset>0x04</addressOffset>
            <resetValue>0x00000000</resetValue>
          </register>
          <register>
            <name>CFG</name>
            <description>TX Configuration</description>
            <addressOffset>0x08</addressOffset>
            <resetValue>0x00000000</resetValue>
             <fields>
                <field>
                    <name>CONT</name>
                    <description>Continuous Mode</description>
                    <bitOffset>0</bitOffset>
                    <bitWidth>1</bitWidth>
                </field>
                <field>
                    <name>SIZE</name>
                    <description>Data Size (00=8bit, 01=16bit, 10=32bit)</description>
                    <bitOffset>1</bitOffset>
                    <bitWidth>2</bitWidth>
                </field>
                <field>
                    <name>EN</name>
                    <description>Enable Channel</description>
                    <bitOffset>4</bitOffset>
                    <bitWidth>1</bitWidth>
                </field>
                 <field>
                    <name>PENDING</name>
                    <description>Transfer Pending Status</description>
                    <bitOffset>5</bitOffset>
                    <bitWidth>1</bitWidth>
                </field>
                <field>
                    <name>CLR</name>
                    <description>Clear Channel</description>
                    <bitOffset>6</bitOffset>
                    <bitWidth>1</bitWidth>
                </field>
            </fields>
          </register>
        </cluster>

        <!-- UART Custom Registers -->
        <register>
          <name>STATUS</name>
          <description>UART Status Register</description>
          <addressOffset>0x20</addressOffset>
          <fields>
            <field>
              <name>TX_BUSY</name>
              <description>TX Busy</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RX_BUSY</name>
              <description>RX Busy</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>SETUP</name>
          <description>UART Setup Register</description>
          <addressOffset>0x24</addressOffset>
          <fields>
            <field>
              <name>PARITY_ENA</name>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>BIT_LENGTH</name>
              <bitOffset>1</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>STOP_BITS</name>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>TX_ENA</name>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>RX_ENA</name>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>CLKDIV</name>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
            <name>ERROR</name>
            <description>UART Error Register</description>
            <addressOffset>0x28</addressOffset>
        </register>
        <register>
            <name>IRQ_EN</name>
            <description>UART IRQ Enable Register</description>
            <addressOffset>0x2C</addressOffset>
        </register>
      </registers>
    </peripheral>

    <peripheral derivedFrom="UART0">
      <name>UART1</name>
      <baseAddress>0x50102000</baseAddress>
      <interrupt><name>UART1_RX</name><value>68</value></interrupt>
      <interrupt><name>UART1_TX</name><value>69</value></interrupt>
      <interrupt><name>UART1_RX_CHAR</name><value>70</value></interrupt>
      <interrupt><name>UART1_ERR</name><value>71</value></interrupt>
    </peripheral>

    <peripheral derivedFrom="UART0">
      <name>UART2</name>
      <baseAddress>0x50103000</baseAddress>
      <interrupt><name>UART2_RX</name><value>72</value></interrupt>
      <interrupt><name>UART2_TX</name><value>73</value></interrupt>
      <interrupt><name>UART2_RX_CHAR</name><value>74</value></interrupt>
      <interrupt><name>UART2_ERR</name><value>75</value></interrupt>
    </peripheral>

    <peripheral derivedFrom="UART0">
      <name>UART3</name>
      <baseAddress>0x50104000</baseAddress>
      <interrupt><name>UART3_RX</name><value>76</value></interrupt>
      <interrupt><name>UART3_TX</name><value>77</value></interrupt>
      <interrupt><name>UART3_RX_CHAR</name><value>78</value></interrupt>
      <interrupt><name>UART3_ERR</name><value>79</value></interrupt>
    </peripheral>

    <!-- SPIM0: UDMA SPI Master -->
    <peripheral>
      <name>SPIM0</name>
      <description>SPI Master 0</description>
      <baseAddress>0x50105000</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x1000</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt><name>SPIM0_RX</name><value>80</value></interrupt>
      <interrupt><name>SPIM0_TX</name><value>81</value></interrupt>
      <interrupt><name>SPIM0_CMD</name><value>82</value></interrupt>
      <interrupt><name>SPIM0_EOT</name><value>83</value></interrupt>

      <registers>
         <!-- RX Channel -->
        <cluster>
          <name>RX_CHANNEL</name>
          <description>UDMA RX Channel</description>
          <addressOffset>0x00</addressOffset>
          <register>
            <name>SADDR</name>
            <description>RX Buffer Start Address</description>
            <addressOffset>0x00</addressOffset>
            <resetValue>0x00000000</resetValue>
          </register>
          <register>
            <name>SIZE</name>
            <description>RX Buffer Size</description>
            <addressOffset>0x04</addressOffset>
