            <register><name>INTCR1</name><addressOffset>0x04</addressOffset></register>
            <register><name>INTCR2</name><addressOffset>0x08</addressOffset></register>
            <register><name>INTCR3</name><addressOffset>0x0C</addressOffset></register>
            <register><name>INTCR4</name><addressOffset>0x10</addressOffset></register>
            <register><name>INTCR5</name><addressOffset>0x14</addressOffset></register>
            <register><name>INTCR6</name><addressOffset>0x18</addressOffset></register>
            <register><name>INTCR7</name><addressOffset>0x1C</addressOffset></register>
        </cluster>

        <!-- OUT (0x130), OE (0x148), PU (0x160), IN (0x178) -->
        <register><name>OUT_PA</name><addressOffset>0x130</addressOffset></register>
        <register><name>OUT_PB</name><addressOffset>0x134</addressOffset></register>
        <register><name>OUT_PC</name><addressOffset>0x138</addressOffset></register>
        <register><name>OUT_PD</name><addressOffset>0x13C</addressOffset></register>
