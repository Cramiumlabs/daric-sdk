            <register><name>XIP_WIDTH</name><addressOffset>0x0018</addressOffset></register>
            <register><name>XIP_SSEL</name><addressOffset>0x001C</addressOffset></register>
            <register><name>XIP_DUMCYCS</name><addressOffset>0x0020</addressOffset></register>
            <register><name>XIP_CFG</name><addressOffset>0x0024</addressOffset></register>
            
            <register><name>CSR_CTRL</name><addressOffset>0x0200</addressOffset><resetValue>0x00000040</resetValue></register>
            <register><name>CSR_CMD_CTRL</name><addressOffset>0x0204</addressOffset><resetValue>0x00000100</resetValue></register>
            <register><name>CSR_FIFO_FLUSH</name><addressOffset>0x0208</addressOffset></register>
            <register><name>CSR_FIFO_THRESHOLD</name><addressOffset>0x020C</addressOffset></register>
            <register><name>CSR_FIFO_STATUS</name><addressOffset>0x0210</addressOffset><resetValue>0xA8202080</resetValue></register>
            <register><name>CSR_CMD_FIFO_STATUS</name><addressOffset>0x0214</addressOffset><resetValue>0x00002820</resetValue></register>
            <register><name>CSR_IRQ_ENABLE</name><addressOffset>0x0218</addressOffset></register>
            <register><name>CSR_IRQ_STATUS</name><addressOffset>0x021C</addressOffset></register>
            <register><name>CSR_TX_FIFO</name><addressOffset>0x0230</addressOffset></register>
            <register><name>CSR_RX_FIFO</name><addressOffset>0x0234</addressOffset></register>
            <register><name>CSR_CMD_FIFO</name><addressOffset>0x0238</addressOffset></register>
        </registers>
    </peripheral>

    <!-- PWM Peripheral -->
    <peripheral>
        <name>PWM</name>
        <description>Pulse Width Modulation</description>
        <baseAddress>0x50120000</baseAddress>
        <addressBlock><offset>0</offset><size>0x1000</size><usage>registers</usage></addressBlock>
        <interrupt><name>PWM_T0</name><value>140</value></interrupt>
        <interrupt><name>PWM_T1</name><value>141</value></interrupt>
        <interrupt><name>PWM_T2</name><value>142</value></interrupt>
        <interrupt><name>PWM_T3</name><value>143</value></interrupt>
        <registers>
            <cluster>
                <name>TIMER[%s]</name>
                <dim>4</dim>
                <dimIncrement>0x40</dimIncrement>
                <addressOffset>0x00</addressOffset>
                <register><name>CMD</name><addressOffset>0x00</addressOffset></register>
                <register><name>CONFIG</name><addressOffset>0x04</addressOffset></register>
                <register><name>THRESHOLD</name><addressOffset>0x08</addressOffset></register>
                <register>
                    <name>TH_CHANNEL[%s]</name>
                    <dim>4</dim>
                    <dimIncrement>0x04</dimIncrement>
                    <addressOffset>0x0C</addressOffset>
                </register>
                <register><name>COUNTER</name><addressOffset>0x2C</addressOffset><access>read-only</access></register>
            </cluster>
            <register><name>EVENT_CFG</name><addressOffset>0x100</addressOffset></register>
            <register><name>CG</name><addressOffset>0x104</addressOffset></register>
            <register>
                <name>PREFD[%s]</name>
                <dim>4</dim>
                <dimIncrement>0x04</dimIncrement>
                <addressOffset>0x140</addressOffset>
            </register>
        </registers>
    </peripheral>

    <!-- USB Peripheral -->
    <peripheral>
        <name>USB</name>
        <description>USB Controller</description>
        <baseAddress>0x50202400</baseAddress>
        <addressBlock><offset>0</offset><size>0x1000</size><usage>registers</usage></addressBlock>
        <interrupt><name>USB</name><value>145</value></interrupt>
        <registers>
            <register>
                <name>DEVCAP</name>
                <description>Device Capability</description>
                <addressOffset>0x0000</addressOffset>
                <access>read-only</access>
                <fields>
                    <field><name>VERSION</name><description>Version of Programming Interface</description><bitOffset>0</bitOffset><bitWidth>8</bitWidth></field>
                    <field><name>EP_IN_NUM</name><description>Number of Physical EP IN</description><bitOffset>8</bitOffset><bitWidth>4</bitWidth></field>
                    <field><name>EP_OUT_NUM</name><description>Number of Physical EP OUT</description><bitOffset>12</bitOffset><bitWidth>4</bitWidth></field>
                    <field><name>MAX_INT</name><description>Max Interrupts</description><bitOffset>16</bitOffset><bitWidth>11</bitWidth></field>
                    <field><name>GEN1</name><description>Gen1 Support</description><bitOffset>27</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>GEN2</name><description>Gen2 Support</description><bitOffset>28</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>ISOCH</name><description>Isoch Support</description><bitOffset>29</bitOffset><bitWidth>1</bitWidth></field>
                </fields>
            </register>
            <register><name>DEVCONFIG</name><addressOffset>0x0010</addressOffset></register>
            <register><name>EVENTCONFIG</name><addressOffset>0x0014</addressOffset></register>
            <register>
                <name>USBCMD</name>
                <description>USB Command</description>
                <addressOffset>0x0020</addressOffset>
                <fields>
                    <field><name>RUN_STOP</name><description>Run/Stop</description><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>RESET</name><description>Soft Reset</description><bitOffset>1</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>INT_EN</name><description>Interrupt Enable</description><bitOffset>2</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>SYS_ERR_EN</name><description>System Error Enable</description><bitOffset>3</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>EWE</name><description>Enable MFINDEX Wrap Event</description><bitOffset>10</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>FORCE_TERM</name><description>Force Termination</description><bitOffset>11</bitOffset><bitWidth>1</bitWidth></field>
                </fields>
            </register>
            <register>
                <name>USBSTS</name>
                <description>USB Status</description>
                <addressOffset>0x0024</addressOffset>
                <fields>
                    <field><name>HALTED</name><description>Controller Halted</description><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>SYS_ERR</name><description>System Error</description><bitOffset>2</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>EINT</name><description>Event Interrupt</description><bitOffset>3</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>IDLE</name><description>Controller Idle</description><bitOffset>12</bitOffset><bitWidth>1</bitWidth></field>
                </fields>
            </register>
            <register><name>DCBAPLO</name><addressOffset>0x0028</addressOffset></register>
            <register><name>DCBAPHI</name><addressOffset>0x002C</addressOffset></register>
            <register>
                <name>PORTSC</name>
                <description>Port Status and Control</description>
                <addressOffset>0x0030</addressOffset>
                <fields>
                    <field><name>CCS</name><description>Current Connection Status</description><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>PP</name><description>Power Present</description><bitOffset>3</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>PR</name><description>Port Reset</description><bitOffset>4</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>PLS</name><description>Port Link State</description><bitOffset>5</bitOffset><bitWidth>4</bitWidth></field>
                    <field><name>SPEED</name><description>Port Speed</description><bitOffset>10</bitOffset><bitWidth>4</bitWidth></field>
                    <field><name>LWS</name><description>Link Write Strobe</description><bitOffset>16</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>CSC</name><description>Connect Status Change</description><bitOffset>17</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>PPC</name><description>Port Power Change</description><bitOffset>20</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>PRC</name><description>Port Reset Change</description><bitOffset>21</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>PLC</name><description>Port Link State Change</description><bitOffset>22</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>CEC</name><description>Config Error Change</description><bitOffset>23</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>WPR</name><description>Warm Port Reset</description><bitOffset>31</bitOffset><bitWidth>1</bitWidth></field>
                </fields>
            </register>
            <register><name>DOORBELL</name><addressOffset>0x0040</addressOffset></register>
            <register><name>EPENABLE</name><addressOffset>0x0060</addressOffset></register>
            <register><name>EPRUNNING</name><addressOffset>0x0064</addressOffset><access>read-only</access></register>
            <register><name>CMDPARA0</name><addressOffset>0x0070</addressOffset></register>
            <register><name>CMDPARA1</name><addressOffset>0x0074</addressOffset></register>
            <register><name>CMDCTRL</name><addressOffset>0x0078</addressOffset></register>
            
            <register>
                <name>IMAN</name>
                <dim>4</dim>
                <dimIncrement>0x20</dimIncrement>
                <addressOffset>0x0100</addressOffset>
            </register>
            <register>
                <name>IMOD</name>
