    <!-- ATIMER Peripheral -->
    <peripheral>
        <name>ATIMER</name>
        <description>Advanced Timer</description>
        <baseAddress>0x40043000</baseAddress>
        <addressBlock><offset>0</offset><size>0x1000</size><usage>registers</usage></addressBlock>
        <registers>
            <!-- CFG_LO -->
            <register>
                <name>CFG_LO</name>
                <description>Timer Low Configuration register</description>
                <addressOffset>0x0000</addressOffset>
                <resetValue>0x00000000</resetValue>
                <fields>
                    <field><name>EN</name><description>Timer enable (starts counting) bit</description><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>RST</name><description>Timer low reset, cleared after the reset happened</description><bitOffset>1</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>IRQEN</name><description>Timer low interrupt generation on compare match enable</description><bitOffset>2</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>MODE</name><description>Timer low continuous mode configuration</description><bitOffset>4</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>ONES</name><description>Timer low one shot configuration</description><bitOffset>5</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>PEN</name><description>Timer low prescaler enable bit</description><bitOffset>6</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>CCFG</name><description>Timer low clock source configuration</description><bitOffset>7</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>PVAL</name><description>Timer low prescaler value</description><bitOffset>8</bitOffset><bitWidth>8</bitWidth></field>
                    <field><name>CASC</name><description>Timer low and Timer high 64-bit cascaded mode enable bit</description><bitOffset>31</bitOffset><bitWidth>1</bitWidth></field>
                </fields>
            </register>
            <!-- CFG_HI -->
            <register>
                <name>CFG_HI</name>
                <description>Timer High Configuration register</description>
                <addressOffset>0x0004</addressOffset>
                <resetValue>0x00000000</resetValue>
                <fields>
                    <field><name>EN</name><description>Timer enable (starts counting) bit</description><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>RST</name><description>Timer High reset, cleared after the reset happened</description><bitOffset>1</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>IRQEN</name><description>Timer High interrupt generation on compare match enable</description><bitOffset>2</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>MODE</name><description>Timer High continuous mode configuration</description><bitOffset>4</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>ONES</name><description>Timer High one shot configuration</description><bitOffset>5</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>PEN</name><description>Timer High prescaler enable bit</description><bitOffset>6</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>CCFG</name><description>Timer low clock source configuration</description><bitOffset>7</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>PVAL</name><description>Timer High prescaler value</description><bitOffset>8</bitOffset><bitWidth>8</bitWidth></field>
                </fields>
            </register>
            <!-- CNT_LO -->
            <register>
                <name>CNT_LO</name>
                <description>Timer Low counter value register</description>
                <addressOffset>0x0008</addressOffset>
                <resetValue>0x00000000</resetValue>
            </register>
            <!-- CNT_HI -->
            <register>
                <name>CNT_HI</name>
                <description>Timer High counter value register</description>
                <addressOffset>0x000C</addressOffset>
                <resetValue>0x00000000</resetValue>
            </register>
            <!-- CMP_LO -->
            <register>
                <name>CMP_LO</name>
                <description>Timer Low comparator value register</description>
                <addressOffset>0x0010</addressOffset>
                <resetValue>0x00000000</resetValue>
            </register>
            <!-- CMP_HI -->
            <register>
                <name>CMP_HI</name>
                <description>Timer High comparator value register</description>
                <addressOffset>0x0014</addressOffset>
                <resetValue>0x00000000</resetValue>
            </register>
            <!-- START_LO -->
            <register>
                <name>START_LO</name>
                <description>Start Timer Low counting register</description>
                <addressOffset>0x0018</addressOffset>
                <resetValue>0x00000000</resetValue>
                <fields>
                   <field><name>S</name><description>Timer start command</description><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                </fields>
            </register>
            <!-- START_HI -->
            <register>
                <name>START_HI</name>
                <description>Start Timer High counting register</description>
                <addressOffset>0x001C</addressOffset>
                <resetValue>0x00000000</resetValue>
               <fields>
                   <field><name>S</name><description>Timer start command</description><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                </fields>
            </register>
             <!-- RESET_LO -->
            <register>
                <name>RESET_LO</name>
                <description>Reset Timer Low counter register</description>
                <addressOffset>0x0020</addressOffset>
                <resetValue>0x00000000</resetValue>
                <fields>
                   <field><name>R</name><description>Timer reset command</description><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                </fields>
            </register>
            <!-- RESET_HI -->
            <register>
                <name>RESET_HI</name>
                <description>Reset Timer High counter register</description>
                <addressOffset>0x0024</addressOffset>
                <resetValue>0x00000000</resetValue>
                 <fields>
                   <field><name>R</name><description>Timer reset command</description><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                </fields>
            </register>
        </registers>
    </peripheral>

    <peripheral>
        <name>PMU</name>
        <description>Power Management Unit &amp; Always-On Domain Control</description>
        <baseAddress>0x40060000</baseAddress>
        <addressBlock><offset>0</offset><size>0x1000</size><usage>registers</usage></addressBlock>
        <registers>
            <register>
                <name>AO_CLK32K_SEL</name>
                <description>Always on clock 32KHz source selection</description>
                <addressOffset>0x00</addressOffset>
                <resetValue>0x00000006</resetValue>
                <fields>
                    <field><name>CLK_SEL</name><description>32k clock source: 0=internal OSC, 1=external XTAL</description><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>PDISOEN</name><description>Isolation control in power-down</description><bitOffset>1</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>PCLKICG</name><description>PCLK ICG control in power-down</description><bitOffset>2</bitOffset><bitWidth>1</bitWidth></field>
                </fields>
            </register>
            <register>
                <name>AO_CLK1HZ_FD</name>
                <description>clk 1Hz frequency division configuration</description>
                <addressOffset>0x04</addressOffset>
                <resetValue>0x00003FFF</resetValue>
                <fields>
                    <field><name>FD</name><description>1Hz frequency division</description><bitOffset>0</bitOffset><bitWidth>14</bitWidth></field>
                </fields>
            </register>
            <register>
                <name>AO_WKUP_INTEN</name>
                <description>Wakeup mask and interrupt enable</description>
                <addressOffset>0x08</addressOffset>
                <fields>
                    <field><name>WDT_RST_IE</name><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>RTC_IE</name><bitOffset>1</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>ATIMER_IE</name><bitOffset>2</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>WDT_EV_IE</name><bitOffset>3</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>KPC_EV_IE</name><bitOffset>4</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>KPC_ASYNC_IE</name><bitOffset>5</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>WDT_RST_MSK</name><bitOffset>8</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>RTC_MSK</name><bitOffset>9</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>WDT_EV_MSK</name><bitOffset>11</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>KPC_EV_MSK</name><bitOffset>12</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>KPC_ASYNC_MSK</name><bitOffset>13</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>PF1_PD_MSK</name><bitOffset>16</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>PF0_PD_MSK</name><bitOffset>17</bitOffset><bitWidth>1</bitWidth></field>
                </fields>
            </register>
            <register>
                <name>AO_RSTCR_MASK</name>
                <description>Reset mask control</description>
                <addressOffset>0x0C</addressOffset>
                <resetValue>0x0000001F</resetValue>
                <fields>
                    <field><name>PMU_POR_MSK</name><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>PMU_0V8D_MSK</name><bitOffset>1</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>PMU_0V8A_MSK</name><bitOffset>2</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>PMU_2V5_MSK</name><bitOffset>3</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>PMU_BG_MSK</name><bitOffset>4</bitOffset><bitWidth>1</bitWidth></field>
                </fields>
            </register>
            <register>
                <name>PMU_CR</name>
                <description>PMU control register</description>
                <addressOffset>0x10</addressOffset>
                <resetValue>0x0000007C</resetValue>
                 <fields>
                    <field><name>V8D_SEL</name><description>0: 0.8V, 1: 0.95V</description><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>V8A_SEL</name><description>0: 0.8V, 1: 0.95V</description><bitOffset>1</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>POC_EN</name><bitOffset>2</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>IOUT_EN</name><bitOffset>3</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>V8D_EN</name><bitOffset>4</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>V8A_EN</name><bitOffset>5</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>V25_EN</name><bitOffset>6</bitOffset><bitWidth>1</bitWidth></field>
                </fields>
            </register>
            <register><name>PMU_CRLP</name><description>Low Power Control</description><addressOffset>0x14</addressOffset></register>
            <register><name>PMU_CRPD</name><description>Power Down Control</description><addressOffset>0x18</addressOffset></register>
            <register><name>PMU_DFT</name><description>Default Test</description><addressOffset>0x1C</addressOffset></register>
            <register>
                <name>PMU_TRM0</name>
                <description>Trim 0</description>
                <addressOffset>0x20</addressOffset>
                 <fields>
                    <field><name>VDDAO_TRM</name><bitOffset>0</bitOffset><bitWidth>3</bitWidth></field>
                    <field><name>V8D_TRM</name><bitOffset>3</bitOffset><bitWidth>5</bitWidth></field>
                    <field><name>V8A_TRM</name><bitOffset>8</bitOffset><bitWidth>5</bitWidth></field>
                    <field><name>V25_TRM</name><bitOffset>13</bitOffset><bitWidth>5</bitWidth></field>
                    <field><name>CTAT_TRM</name><bitOffset>18</bitOffset><bitWidth>5</bitWidth></field>
                    <field><name>PTAT_TRM</name><bitOffset>23</bitOffset><bitWidth>5</bitWidth></field>
                    <field><name>ISINK_TRM_L</name><bitOffset>28</bitOffset><bitWidth>4</bitWidth></field>
                </fields>
            </register>
            <register>
                <name>PMU_TRM1</name>
                <description>Trim 1</description>
                <addressOffset>0x24</addressOffset>
                <fields>
                    <field><name>ISINK_TRM_H</name><bitOffset>0</bitOffset><bitWidth>2</bitWidth></field>
                </fields>
            </register>
            <register><name>PMU_TRMLP0</name><description>Trim Low Power 0</description><addressOffset>0x28</addressOffset></register>
            <register><name>PMU_TRMLP1</name><description>Trim Low Power 1</description><addressOffset>0x2C</addressOffset></register>
            <register>
                <name>AO_OSC_CR</name>
                <description>Always-on 32KHz oscillator IP control</description>
                <addressOffset>0x34</addressOffset>
            </register>
            <register>
                <name>PMU_SR</name>
                <description>Status Register</description>
                <addressOffset>0x38</addressOffset>
                 <fields>
                    <field><name>POR_RDY</name><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>V8D_RDY</name><bitOffset>1</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>V8A_RDY</name><bitOffset>2</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>V25_RDY</name><bitOffset>3</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>BG_RDY</name><bitOffset>4</bitOffset><bitWidth>1</bitWidth></field>
                </fields>
            </register>
            <register>
                <name>PMU_FR</name>
                <description>Flag Register</description>
                <addressOffset>0x3C</addressOffset>
                <fields>
                     <field><name>POR_ERR</name><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>V8D_ERR</name><bitOffset>1</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>V8A_ERR</name><bitOffset>2</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>V25_ERR</name><bitOffset>3</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>BG_ERR</name><bitOffset>4</bitOffset><bitWidth>1</bitWidth></field>
                </fields>
            </register>
             <register>
                <name>AO_FR</name>
                <description>AO domain interrupt flag register</description>
                <addressOffset>0x40</addressOffset>
                 <fields>
                    <field><name>WDT_RST_INT</name><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>RTC_INT</name><bitOffset>1</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>ATIMER_INT</name><bitOffset>2</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>WDT_EV_INT</name><bitOffset>3</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>KPC_EV_INT</name><bitOffset>4</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>KPC_ASYNC_INT</name><bitOffset>5</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>PF1_PD</name><bitOffset>8</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>PF0_PD</name><bitOffset>9</bitOffset><bitWidth>1</bitWidth></field>
                 </fields>
            </register>
            <register><name>PMU_PDAR</name><description>Power Down AR</description><addressOffset>0x44</addressOffset></register>
            <register><name>AO_PERI_CLR</name><description>Wake up interrupt clear AR</description><addressOffset>0x50</addressOffset></register>
            <register><name>AO_IOX</name><description>AO IO Pad(Bank F) AF selection</description><addressOffset>0x60</addressOffset></register>
            <register><name>AO_PADPU</name><description>AO IO Pad(Bank F) pull up configuration</description><addressOffset>0x64</addressOffset></register>
        </registers>
    </peripheral>
    <!-- RTC Peripheral -->
    <peripheral>
        <name>RTC</name>
        <description>Real Time Clock</description>
        <baseAddress>0x40061000</baseAddress>
        <addressBlock><offset>0</offset><size>0x1000</size><usage>registers</usage></addressBlock>
        <interrupt><name>RTC</name><value>30</value></interrupt>
        <registers>
            <register><name>DR</name><description>Data register</description><addressOffset>0x00</addressOffset><access>read-only</access></register>
            <register><name>MR</name><description>Match register</description><addressOffset>0x04</addressOffset></register>
            <register><name>LR</name><description>Load register</description><addressOffset>0x08</addressOffset></register>
            <register>
                <name>CR</name>
                <description>Control register</description>
                <addressOffset>0x0C</addressOffset>
                <fields>
                    <field><name>START</name><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                </fields>
            </register>
            <register>
                <name>IMSC</name>
                <description>Interrupt Set or Clear</description>
                <addressOffset>0x10</addressOffset>
                 <fields>
                    <field><name>IM</name><description>Interrupt Mask: 1=Enable</description><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                </fields>
            </register>
            <register>
                <name>RIS</name>
                <description>Raw Interrupt Status</description>
                <addressOffset>0x14</addressOffset>
                <access>read-only</access>
                 <fields>
                    <field><name>RIS</name><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                </fields>
            </register>
             <register>
                <name>MIS</name>
                <description>Masked Interrupt Status</description>
                <addressOffset>0x18</addressOffset>
                <access>read-only</access>
                 <fields>
                    <field><name>MIS</name><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                </fields>
            </register>
            <register>
                <name>ICR</name>
                <description>Interrupt Clear Register</description>
                <addressOffset>0x1C</addressOffset>
                <access>write-only</access>
                 <fields>
                    <field><name>ICR</name><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                </fields>
            </register>
        </registers>
    </peripheral>

    <!-- AO WDT Peripheral (Derived) -->
    <peripheral derivedFrom="WDT">
        <name>WDT_AO</name>
        <baseAddress>0x40062000</baseAddress>
        <interrupt><name>AO_WDT</name><value>30</value></interrupt> <!-- Shared IRQ 30 -->
    </peripheral>

    <!-- AO ATIMER Peripheral (Derived) -->
    <peripheral derivedFrom="ATIMER">
        <name>ATIMER_AO</name>
        <baseAddress>0x40063000</baseAddress>
        <interrupt><name>AO_ATIMER</name><value>30</value></interrupt> <!-- Shared IRQ 30 -->
    </peripheral>

    <!-- KPC Peripheral -->
    <peripheral>
        <name>KPC</name>
        <description>Keypad Controller</description>
        <baseAddress>0x40064000</baseAddress>
        <addressBlock><offset>0</offset><size>0x1000</size><usage>registers</usage></addressBlock>
        <interrupt><name>KPC</name><value>30</value></interrupt>
        <registers>
            <register>
                <name>CFG0</name>
                <description>Enable configuration</description>
                <addressOffset>0x00</addressOffset>
                <resetValue>0x0000000D</resetValue>
                <fields>
                    <field><name>KPOPO0</name><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>KPOPO1</name><bitOffset>1</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>KPOOE0</name><bitOffset>2</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>KPOOE1</name><bitOffset>3</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>EN</name><bitOffset>4</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>AUTOSLEEP</name><bitOffset>5</bitOffset><bitWidth>1</bitWidth></field>
                </fields>
            </register>
            <register>
                <name>CFG1</name>
                <description>Time configuration</description>
                <addressOffset>0x04</addressOffset>
                <resetValue>0x001F1010</resetValue>
                <fields>
                    <field><name>CFG_STEP</name><bitOffset>0</bitOffset><bitWidth>8</bitWidth></field>
                    <field><name>CFG_FILTER</name><bitOffset>8</bitOffset><bitWidth>8</bitWidth></field>
                    <field><name>CFG_CNT1MS</name><bitOffset>16</bitOffset><bitWidth>8</bitWidth></field>
                </fields>
            </register>
            <register>
                <name>CFG2</name>
                <description>Sample timing configuration</description>
                <addressOffset>0x08</addressOffset>
                <resetValue>0xFF201810</resetValue>
                <fields>
                    <field><name>CFG_CNT0</name><bitOffset>0</bitOffset><bitWidth>8</bitWidth></field>
                    <field><name>CFG_CNT1</name><bitOffset>8</bitOffset><bitWidth>8</bitWidth></field>
                    <field><name>CFG_CNT2</name><bitOffset>16</bitOffset><bitWidth>8</bitWidth></field>
                    <field><name>CFG_CNT3</name><bitOffset>24</bitOffset><bitWidth>8</bitWidth></field>
                </fields>
            </register>
            <register>
                <name>CFG3</name>
                <description>Node configuration</description>
                <addressOffset>0x0C</addressOffset>
                <resetValue>0xFFFFFFFF</resetValue>
                <fields>
                    <field><name>RISE_IE</name><bitOffset>0</bitOffset><bitWidth>16</bitWidth></field>
                    <field><name>FALL_IE</name><bitOffset>16</bitOffset><bitWidth>16</bitWidth></field>
                </fields>
            </register>
            <register>
                <name>SRO</name>
                <description>Status register 0</description>
                <addressOffset>0x10</addressOffset>
                <access>read-only</access>
                 <fields>
                    <field><name>NODE_REG</name><bitOffset>0</bitOffset><bitWidth>16</bitWidth></field>
                    <field><name>KPI0_PI</name><bitOffset>16</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>KPI1_PI</name><bitOffset>17</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>KPI2_PI</name><bitOffset>18</bitOffset><bitWidth>1</bitWidth></field>
                    <field><name>KPI3_PI</name><bitOffset>19</bitOffset><bitWidth>1</bitWidth></field>
                </fields>
            </register>
            <register>
                <name>SR1</name>
                <description>Status register 1</description>
                <addressOffset>0x14</addressOffset>
                <access>read-only</access>
                <fields>
                    <field><name>EVENT_FIFO_VALID</name><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
                </fields>
            </register>
            <register>
                <name>FF</name>
                <description>FIFO/Event register</description>
                <addressOffset>0x20</addressOffset>
                 <fields>
                    <field><name>EVENT_INDEX</name><bitOffset>0</bitOffset><bitWidth>5</bitWidth></field>
                    <field><name>EVTIMING</name><bitOffset>16</bitOffset><bitWidth>16</bitWidth></field>
                </fields>
            </register>
            <register>
                <name>CFG4</name>
                <description>Sleep wait time configuration</description>
                <addressOffset>0x30</addressOffset>
                <resetValue>0x000001F4</resetValue>
                 <fields>
                    <field><name>CFG_DEEP10MS</name><bitOffset>0</bitOffset><bitWidth>16</bitWidth></field>
                </fields>
            </register>
        </registers>
    </peripheral>

    <!-- QFC Peripheral -->
    <peripheral>
        <name>QFC</name>
        <description>Quad Flash Controller</description>
        <baseAddress>0x40010000</baseAddress>
