        <register><name>IN_PA</name><addressOffset>0x178</addressOffset></register>
        <register><name>IN_PB</name><addressOffset>0x17C</addressOffset></register>
        <register><name>IN_PC</name><addressOffset>0x180</addressOffset></register>
        <register><name>IN_PD</name><addressOffset>0x184</addressOffset></register>
        <register><name>IN_PE</name><addressOffset>0x188</addressOffset></register>
        <register><name>IN_PF</name><addressOffset>0x18C</addressOffset></register>

        <!-- Schmitt Trigger (0x230) -->
        <register><name>SCHM_PA</name><addressOffset>0x230</addressOffset></register>
