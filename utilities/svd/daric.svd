        <register><name>OE_PC</name><addressOffset>0x150</addressOffset></register>
        <register><name>OE_PD</name><addressOffset>0x154</addressOffset></register>
        <register><name>OE_PE</name><addressOffset>0x158</addressOffset></register>
        <register><name>OE_PF</name><addressOffset>0x15C</addressOffset></register>

        <register><name>PU_PA</name><addressOffset>0x160</addressOffset></register>
        <register><name>PU_PB</name><addressOffset>0x164</addressOffset></register>
        <register><name>PU_PC</name><addressOffset>0x168</addressOffset></register>
        <register><name>PU_PD</name><addressOffset>0x16C</addressOffset></register>
        <register><name>PU_PE</name><addressOffset>0x170</addressOffset></register>
