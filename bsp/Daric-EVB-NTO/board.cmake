# define a macro to set LCD pin configuration
macro(set_lcd_pin name port pin is_required)
    set(CONFIG_LCD_${name}_PORT ${port})
    set(CONFIG_LCD_${name}_PIN ${pin})
    set(CONFIG_LCD_${name}_IS_REQUIRED ${is_required})
endmacro()

# use macro to set LCD pin configuration
set_lcd_pin(VCIEN   GPIOD   GPIO_PIN_11     false)
set_lcd_pin(RST     GPIOD   GPIO_PIN_12     false)
set_lcd_pin(BUSY    GPIOC   GPIO_PIN_13     false)

